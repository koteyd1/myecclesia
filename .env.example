# Copy to apps/vite/.env.local and apps/nextjs/.env.local with real values.
# Each app only reads its own .env.local (no shared root .env).

# --- apps/vite/.env.local ---
# VITE_SUPABASE_PROJECT_ID=
# VITE_SUPABASE_PUBLISHABLE_KEY=
# VITE_SUPABASE_URL=

# --- apps/nextjs/.env.local ---
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# NEXT_PUBLIC_SUPABASE_PROJECT_ID=
# NEXT_PUBLIC_SITE_URL=https://myecclesia.org.uk
